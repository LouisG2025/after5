# =============================================================
#  After5 Agent - Environment Variables (example)
# =============================================================
# Copy to .env and fill in real values for your environment.
# =============================================================

# --- Messaging Provider -----------------------------
# Options: baileys | whatsapp_cloud
# Demo phase: use "baileys" (free, QR-paired to a phone)
# Client deployments: use "whatsapp_cloud" (official Meta API)
MESSAGING_PROVIDER=baileys

# --- Baileys (demo WhatsApp layer) ------------------
# URL of the local Baileys Node service (see /baileys folder)
BAILEYS_SERVICE_URL=http://localhost:3001

# --- WhatsApp Cloud API (production) ----------------
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=after5_verify_token

# --- OpenRouter LLM ---------------------------------
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_PRIMARY_MODEL=anthropic/claude-sonnet-4-5
OPENROUTER_FALLBACK_MODEL=openai/gpt-4o
OPENROUTER_BANT_MODEL=openai/gpt-4o-mini

# --- Helicone (optional LLM observability) ----------
HELICONE_API_KEY=

# --- Redis ------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Supabase ---------------------------------------
SUPABASE_URL=https://yourproject.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# --- Calendly ---------------------------------------
CALENDLY_LINK=https://calendly.com/after5-louis/15min

# --- OpenAI (for Whisper voice transcription) -------
OPENAI_API_KEY=

# --- App Timing -------------------------------------
# Brief spec: 5s silence window, 25s hard max
INPUT_BUFFER_SECONDS=5
INPUT_BUFFER_MAX_SECONDS=25
TYPING_DELAY_PER_CHAR=0.1
CHUNK_DELAY_SECONDS=1.5
MAX_FOLLOWUPS=3
MAX_CHUNKS=3

DEBUG=false

# --- Security -----------------------------------------
# API key for protected endpoints (form-webhook, admin, debug, etc.)
# Leave empty for local dev (no auth required). Set a strong random key for production.
AFTER5_API_KEY=
# Comma-separated allowed CORS origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://apexai.ae,https://www.apexai.ae
